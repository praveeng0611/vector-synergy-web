    "namingConventions": {
      "files": {
        "templates": "PascalCase + Template suffix (e.g., AboutTemplate.tsx)",
        "organisms": "kebab-case (e.g., hero.tsx, contact-info.tsx)",
        "molecules": "PascalCase (e.g., StatCard.tsx, FeatureCard.tsx)",
        "atoms": "PascalCase (e.g., ErrorBoundary.tsx)"
      },
      "components": {
        "templates": "Export default function with Template suffix",
        "organisms": "Export default function with descriptive name", 
        "molecules": "Export default function with component name",
        "atoms": "Export default function with component name"
      }
    },
    "dependencies": {
      "internal": [
        "@/components/ui/*",
        "@/components/atoms/*", 
        "@/components/molecules/*",
        "@/components/organisms/*"
      ],
      "external": [
        "lucide-react",
        "next/link",
        "next/metadata",
        "react"
      ]
    },
    "bestPractices": {
      "separation": "Each organism should handle one main section/responsibility",
      "reusability": "Extract common patterns into molecules",
      "props": "Use TypeScript interfaces for all component props",
      "imports": "Use absolute imports with @ alias",
      "exports": "Use default exports for components",
      "styling": "Use Tailwind CSS with consistent design system",
      "accessibility": "Ensure WCAG AA compliance in all components"
    }
