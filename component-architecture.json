{
  "componentArchitecture": {
    "version": "1.0.0",
    "description": "Vector Synergy Component Architecture following Atomic Design Pattern",
    "lastUpdated": "2024",
    "principles": {
      "atomicDesign": {
        "description": "Component hierarchy based on Atomic Design methodology",
        "levels": {
          "atoms": {
            "description": "Basic building blocks - buttons, inputs, labels, icons",
            "purpose": "Fundamental UI elements that cannot be broken down further",
            "examples": ["ErrorBoundary", "Loading states", "Basic form elements"]
          },
          "molecules": {
            "description": "Simple groups of atoms functioning together as a unit",
            "purpose": "Reusable component combinations that serve a single purpose",
            "examples": ["SearchBox", "FormField", "StatCard", "FeatureCard"]
          },
          "organisms": {
            "description": "Complex UI components made of groups of molecules and atoms",
            "purpose": "Distinct sections of interface that form the major parts of a page",
            "examples": ["Header", "Hero sections", "Service grids", "Contact forms"]
          },
          "templates": {
            "description": "Page-level objects that place components into a layout",
            "purpose": "Define the overall page structure and component arrangement",
            "examples": ["HomeTemplate", "AboutTemplate", "ContactTemplate"]
          },
          "pages": {
            "description": "Specific instances of templates with actual content",
            "purpose": "Final pages that users interact with",
            "examples": ["HomePage", "AboutPage", "ContactPage"]
          }
        }
      }
    },
